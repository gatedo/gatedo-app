generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  phone                  String?
  password               String
  name                   String?
  photoUrl               String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  status                 String                 @default("ACTIVE")
  badges                 String[]               @default([])
  city                   String?
  plan                   String                 @default("FREE")
  planExpires            DateTime?
  role                   Role                   @default(USER)
  emailVerified          Boolean                @default(false)
  emailVerifyToken       String?                @unique
  resetPasswordExpires   DateTime?
  resetPasswordToken     String?                @unique
  level                  Int                    @default(1)
  founderBonusMonthsPaid Int                    @default(0)
  founderGrantedAt       DateTime?
  gatedoPoints           Int                    @default(0)
  xpt                    Int                    @default(0)
  balanceActionsMade     BalanceAdjustmentLog[] @relation("BalanceActor")
  balanceLogs            BalanceAdjustmentLog[] @relation("BalanceTarget")
  comments               Comment[]
  targetCoupons          Coupon[]               @relation("CouponTarget")
  couponRedemptions      CouponRedemption[]
  documents              Document[]
  memorialTributes       MemorialTribute[]
  notifications          Notification[]
  orders                 Order[]
  pets                   Pet[]
  petAchievements        PetAchievement[]       @relation("PetAchievementGrantedByUser")
  posts                  Post[]
  postLikes              PostLike[]
  postSaves              PostSave[]
  productShares          ProductShare[]
  rewardEvents           RewardEvent[]
  socialFollows          SocialFollow[]         @relation("SocialFollowFollower")
  petFollowers           SocialFollow[]         @relation("SocialFollowPetOwner")
  studioCreations        StudioCreation[]
  subscription           Subscription?
  tutorPoints            TutorPoints?
  achievements           UserAchievement[]
  credits                UserCredits?
  vetProfile             VetPartner?
  vetRecommendations     VetRecommendation[]
  noticeReads            NoticeRead[]
}

model Pet {
  id                    String              @id @default(uuid())
  ownerId               String
  name                  String
  nicknames             String?
  breed                 String?
  themeColor            String?
  photoUrl              String?
  gallery               String[]
  gender                Gender              @default(UNKNOWN)
  birthDate             DateTime?
  deathDate             DateTime?
  isDateEstimated       Boolean             @default(false)
  ageYears              Int?
  ageMonths             Int?
  weight                Float?
  city                  String?
  microchip             String?
  neutered              Boolean             @default(false)
  neuterIntention       String?
  healthSummary         String?
  foodBrand             String?
  foodFreq              String?
  foodType              String[]
  personality           String[]
  activityLevel         String?
  socialOtherPets       String?
  behaviorIssues        String?
  traumaHistory         String?
  housingType           String?
  streetAccess          Boolean             @default(false)
  adoptionStory         String?
  hasAwards             Boolean             @default(false)
  awardsDetail          String?
  isArchived            Boolean             @default(false)
  isMemorial            Boolean             @default(false)
  showInHome            Boolean             @default(true)
  level                 Int                 @default(1)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  bio                   String?
  foodAmount            String?
  pedigreeUrl           String?
  skillAgility          String              @default("85")
  skillCuriosity        String              @default("90")
  skillDocile           String              @default("95")
  skillEnergy           String              @default("75")
  skillIndep            String              @default("60")
  skillSocial           String              @default("80")
  habitat               String?
  riskAreaAccess        Boolean             @default(false)
  deathCause            String?
  pedigreeBackUrl       String?
  badges                String[]            @default([])
  xpg                   Int                 @default(0)
  arrivalNotes          String?
  arrivalType           String?
  coatType              String?
  coexistsWith          String[]            @default([])
  feedFrequencyMode     String?
  feedFrequencyNotes    String?
  hasBehaviorIssues     Boolean             @default(false)
  hasTraumaHistory      Boolean             @default(false)
  preExistingConditions String[]            @default([])
  diaryEntries          DiaryEntry[]
  documents             Document[]
  healthRecords         HealthRecord[]
  igentSessions         IgentSession[]
  memorial              MemorialTribute?
  owner                 User                @relation(fields: [ownerId], references: [id])
  achievements          PetAchievement[]
  posts                 Post[]
  rewardEvents          RewardEvent[]
  followers             SocialFollow[]
  studioCreations       StudioCreation[]
  treatments            TreatmentSchedule[]
}

model HealthRecord {
  id                 String     @id @default(uuid())
  petId              String
  type               HealthType
  title              String
  date               DateTime
  nextDueDate        DateTime?
  batchNumber        String?
  veterinarian       String?
  clinic             String?
  notes              String?
  attachmentUrl      String?
  active             Boolean    @default(false)
  appointmentMode    String?
  clinicAddress      String?
  clinicName         String?
  clinicPhone        String?
  isControlled       Boolean    @default(false)
  ongoing            Boolean    @default(false)
  prescription       Boolean    @default(false)
  prescriptionDocId  String?
  reason             String?
  recheckDate        DateTime?
  recommendedRecheck Boolean    @default(false)
  specialty          String?
  pet                Pet        @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model IgentSession {
  id               String    @id @default(uuid())
  petId            String
  date             DateTime  @default(now())
  symptomId        String
  symptomLabel     String
  isUrgent         Boolean
  analysisText     String
  recommendations  Json
  clinicalSnapshot Json
  ownerResponse    String?
  resolvedAt       DateTime?
  severity         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  pet              Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model Document {
  id              String    @id @default(uuid())
  petId           String
  type            String?
  category        String
  cloudExportedAt DateTime?
  cloudPath       String?
  cloudProvider   String?
  createdAt       DateTime  @default(now())
  fileName        String?
  fileUrl         String
  isFavorite      Boolean   @default(false)
  isPrivate       Boolean   @default(true)
  isVetShared     Boolean   @default(false)
  metadata        Json?
  mimeType        String?
  ownerId         String
  size            Int?
  title           String
  updatedAt       DateTime  @updatedAt
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  pet             Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([ownerId])
  @@index([category])
  @@index([createdAt])
}

model MemorialTribute {
  id          String   @id @default(uuid())
  userId      String
  petId       String?  @unique
  name        String
  birthYear   String?
  deathYear   String?
  message     String
  photoUrl    String?
  candleCount Int      @default(0)
  createdAt   DateTime @default(now())
  isPublic    Boolean  @default(true)
  title       String?
  pet         Pet?     @relation(fields: [petId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Post {
  id               String          @id @default(uuid())
  userId           String
  content          String
  imageUrl         String?
  likes            Int             @default(0)
  createdAt        DateTime        @default(now())
  allowComments    Boolean         @default(true)
  allowShare       Boolean         @default(true)
  commentsCount    Int             @default(0)
  featured         Boolean         @default(false)
  petId            String
  savesCount       Int             @default(0)
  sharesCount      Int             @default(0)
  source           String          @default("manual")
  type             String          @default("PHOTO")
  updatedAt        DateTime        @updatedAt
  visibility       PostVisibility  @default(PUBLIC)
  studioCreationId String?
  comments         Comment[]
  pet              Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
  studioCreation   StudioCreation? @relation(fields: [studioCreationId], references: [id])
  user             User            @relation(fields: [userId], references: [id])
  likedBy          PostLike[]
  savedBy          PostSave[]

  @@index([petId, visibility, createdAt])
  @@index([studioCreationId])
  @@index([userId, createdAt])
  @@index([visibility, createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model SocialFollow {
  id         String   @id @default(uuid())
  followerId String
  ownerId    String
  petId      String
  createdAt  DateTime @default(now())
  follower   User     @relation("SocialFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  owner      User     @relation("SocialFollowPetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  pet        Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([followerId, petId])
  @@index([petId])
  @@index([ownerId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model PostSave {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model Achievement {
  id          String               @id @default(uuid())
  title       String
  description String
  iconUrl     String?
  condition   String
  active      Boolean              @default(true)
  category    String?
  code        String               @unique
  pointReward Int                  @default(0)
  rarity      String?              @default("common")
  ownerType   AchievementOwnerType
  xpgReward   Int                  @default(0)
  xptReward   Int                  @default(0)
  pets        PetAchievement[]
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  meta          Json?
  rarity        String?
  source        String?
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model PetAchievement {
  id              String      @id @default(uuid())
  petId           String
  achievementId   String
  grantedByUserId String?
  unlockedAt      DateTime    @default(now())
  rarity          String?
  source          String?
  meta            Json?
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  grantedByUser   User?       @relation("PetAchievementGrantedByUser", fields: [grantedByUserId], references: [id])
  pet             Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([petId, achievementId])
  @@index([petId, unlockedAt])
}

model DiaryEntry {
  id      String   @id @default(uuid())
  petId   String
  title   String
  content String?
  date    DateTime @default(now())
  type    String
  photos  String[]
  pet     Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model StudioCreation {
  id                  String               @id @default(uuid())
  userId              String
  type                StudioType
  originalPhotoUrl    String?
  createdAt           DateTime             @default(now())
  petId               String?
  addedToPetGalleryAt DateTime?
  metadata            Json?
  moduleKey           String?
  moduleLabel         String?
  outputImageUrl      String?
  outputVideoUrl      String?
  previewUrl          String?
  prompt              String?
  publishedAt         DateTime?
  sourceImageUrls     String[]             @default([])
  status              StudioCreationStatus @default(COMPLETED)
  updatedAt           DateTime             @updatedAt
  socialPosts         Post[]
  pet                 Pet?                 @relation(fields: [petId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([petId, createdAt])
  @@index([type, createdAt])
}

model VetRecommendation {
  id         String   @id @default(uuid())
  userId     String
  name       String
  clinicName String?
  address    String?
  city       String?
  phone      String?
  rating     Float    @default(5.0)
  tags       String[]
  isVerified Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Product {
  id            String         @id @default(uuid())
  categoryId    String
  name          String
  description   String
  price         Decimal        @db.Decimal(10, 2)
  promoPrice    Decimal?       @db.Decimal(10, 2)
  images        String[]
  isDigital     Boolean        @default(false)
  externalLink  String?
  stock         Int            @default(0)
  platform      String?
  badge         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  videoReview   String?
  orderItems    OrderItem[]
  category      Category       @relation(fields: [categoryId], references: [id])
  productShares ProductShare[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  products Product[]
}

model Article {
  id        String   @id @default(uuid())
  title     String
  category  String
  imageUrl  String?
  content   String
  author    String   @default("Equipe Gatedo")
  createdAt DateTime @default(now())
}

model StudioAsset {
  id        String   @id @default(uuid())
  title     String
  type      String
  url       String
  isPro     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model VetPartner {
  id         String   @id @default(uuid())
  name       String
  clinicName String
  address    String
  phone      String?
  whatsapp   String?
  photoUrl   String?
  latitude   Float?
  longitude  Float?
  isVerified Boolean  @default(false)
  isPremium  Boolean  @default(false)
  tags       String[]
  rating     Float    @default(0.0)
  reviews    Int      @default(0)
  createdAt  DateTime @default(now())
  ownerId    String?  @unique
  status     String   @default("PENDING")
  owner      User?    @relation(fields: [ownerId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  message     String
  read        Boolean  @default(false)
  petId       String?
  catName     String?
  catBreed    String?
  catPhotoUrl String?
  cta         String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model BalanceAdjustmentLog {
  id          String   @id @default(uuid())
  userId      String
  actorId     String?
  walletDelta Int      @default(0)
  xpDelta     Int      @default(0)
  reason      String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("BalanceActor", fields: [actorId], references: [id])
  user        User     @relation("BalanceTarget", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
}

model TutorPoints {
  id           String   @id @default(uuid())
  userId       String   @unique
  points       Int      @default(0)
  totalEarned  Int      @default(0)
  lastActionAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TreatmentSchedule {
  id                           String          @id @default(uuid())
  petId                        String
  userId                       String
  title                        String
  notes                        String?
  intervalHours                Int
  startDate                    DateTime
  endDate                      DateTime?
  active                       Boolean         @default(true)
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  clinicAddress                String?
  clinicName                   String?
  clinicPhone                  String?
  originHealthRecordId         String?
  originPrescriptionDocumentId String?
  veterinarian                 String?
  doses                        TreatmentDose[]
  pet                          Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model TreatmentDose {
  id          String            @id @default(uuid())
  scheduleId  String
  scheduledAt DateTime
  takenAt     DateTime?
  skipped     Boolean           @default(false)
  notes       String?
  createdAt   DateTime          @default(now())
  schedule    TreatmentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

model AppSettings {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model ProductShare {
  id        String   @id @default(uuid())
  userId    String
  productId String
  token     String   @unique @default(cuid())
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Kit {
  id         String   @id @default(uuid())
  title      String
  subtitle   String   @default("")
  iconName   String   @default("Gift")
  gradient   String   @default("from-yellow-400 to-orange-500")
  productIds String[]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Coupon {
  id           String             @id @default(uuid())
  code         String             @unique
  description  String
  discountType String             @default("POINTS")
  value        Int
  maxUses      Int                @default(1)
  usedCount    Int                @default(0)
  active       Boolean            @default(true)
  expiresAt    DateTime?
  targetUserId String?
  createdAt    DateTime           @default(now())
  targetUser   User?              @relation("CouponTarget", fields: [targetUserId], references: [id])
  redemptions  CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  userId     String
  redeemedAt DateTime @default(now())
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
}

model UserCredits {
  id          String   @id @default(uuid())
  userId      String   @unique
  balance     Int      @default(0)
  totalBought Int      @default(0)
  totalUsed   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FounderInvite {
  id        String    @id @default(uuid())
  token     String    @unique
  email     String
  name      String?
  phase     Int
  orderId   String?
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model Subscription {
  id         String    @id @default(uuid())
  userId     String    @unique
  provider   String    @default("KIWIFY")
  externalId String?
  planType   String
  status     String
  startedAt  DateTime  @default(now())
  expiresAt  DateTime?
  autoRenew  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FounderPhaseConfig {
  phase     Int      @id
  price     Decimal  @db.Decimal(10, 2)
  maxSlots  Int
  soldSlots Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notice {
  id        String       @id @default(uuid())
  title     String
  xpReward  Int          @default(3)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  content   String
  imageUrl  String?
  isActive  Boolean      @default(true)
  type      String       @default("INFO")
  updatedAt DateTime     @updatedAt
  reads     NoticeRead[]
}

model NoticeRead {
  id          String    @id @default(uuid())
  userId      String
  noticeId    String
  readAt      DateTime  @default(now())
  xpGranted   Boolean   @default(false)
  xpGrantedAt DateTime?
  notice      Notice    @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, noticeId])
  @@index([userId])
  @@index([noticeId])
  @@map("notice_reads")
}

model RewardEvent {
  id           String   @id @default(cuid())
  userId       String
  petId        String?
  action       String
  gptsDelta    Int      @default(0)
  xptDelta     Int      @default(0)
  xpgDelta     Int      @default(0)
  badgeGranted String?
  metadata     Json?
  createdAt    DateTime @default(now())
  pet          Pet?     @relation(fields: [petId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([petId, createdAt])
  @@index([action])
}

model Prospect {
  id            String            @id @default(cuid())
  phone         String
  name          String?
  note          String?
  status        String            @default("pending")
  column        String            @default("pending")
  score         Int               @default(0)
  tags          String[]
  sentAt        DateTime?
  repliedAt     DateTime?
  lastReply     String?
  lastMessageId String?
  scriptId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  messages      ProspectMessage[]

  @@index([phone])
  @@index([status])
}

model ProspectMessage {
  id          String   @id @default(cuid())
  prospectId  String
  direction   String
  body        String
  imageUrl    String?
  waMessageId String?
  sentAt      DateTime @default(now())
  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
}

enum Role {
  USER
  ADMIN
  VET
  FOUNDER
  TESTER_VIP
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum HealthType {
  VACCINE
  VERMIFUGE
  PARASITE
  MEDICATION
  EXAM
  SURGERY
  CONSULTATION
  IACONSULT
  MEDICINE
}

enum PostVisibility {
  PRIVATE
  FOLLOWERS
  PUBLIC
}

enum StudioType {
  PORTRAIT
  STICKER
  ID_CARD
  MIND_READER
  TUTOR_CAT
  DANCE
  CAT_VOICE
  ANIMATED_STORY
  MEME_MAKER
  VOGUE_CAT
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum AchievementOwnerType {
  TUTOR
  PET
}

enum StudioCreationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PUBLISHED
}
