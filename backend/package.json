    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/serve-static": "^5.0.4",
    "@prisma/adapter-neon": "^5.21.0",
    "bcrypt": "^6.0.0",
    "openai": "^4.26.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
