{
  "name": "gatedo-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --include=optional sharp",
    "build": "prisma generate && nest build && node -e \"if (!require('fs').existsSync('../client')) { console.warn('⚠️ ATENÇÃO: Pasta ../client não encontrada. O frontend pode não carregar.'); }\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.540.0",
    "@aws-sdk/s3-request-presigner": "3.540.0",
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/common": "11.1.13",
    "@nestjs/core": "11.1.13",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.13",
    "@nestjs/serve-static": "5.0.4",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "5.22.0",
    "bcrypt": "6.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "openai": "4.26.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "resend": "6.9.3",
    "rxjs": "7.8.2",
    "sharp": "0.34.5",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/multer": "1.4.11",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "4.0.1",
    "@types/uuid": "9.0.0",
    "@types/ws": "8.18.1",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "^5.4.5"
  }
}
